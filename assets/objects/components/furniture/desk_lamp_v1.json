{
  "schema_version": 1,
  "name": "desk_lamp_v1",
  "description": "Desk lamp. Level 3 furniture. Components: flat base (cylinder) + vertical pole (cylinder) + horizontal arm (cylinder) + bowl lampshade (inverted hollow hemisphere) + bulb (sphere) + point light. Origin at floor (y=0 = base bottom).",
  "version": 1,
  "parameters": {
    "base_r":   8.0,
    "base_h":   2.0,
    "pole_r":   1.0,
    "pole_h":  35.0,
    "arm_r":    0.8,
    "arm_len": 20.0,
    "shade_r":  7.0,
    "shade_thickness": 1.2,
    "bulb_r":   2.5,
    "light_color_r": 1.0,
    "light_color_g": 0.8,
    "light_color_b": 0.6
  },
  "anchors": {
    "bottom_center": [0, 0, 0],
    "top_center":    [0, "$base_h + $pole_h", 0],
    "arm_end":       ["$arm_len", "$base_h + $pole_h", 0],
    "shade_bottom":  ["$arm_len", "$base_h + $pole_h - $shade_r", 0],
    "center":        ["$arm_len / 2", "($base_h + $pole_h) / 2", 0]
  },
  "root": {
    "type": "group",
    "children": [
      {
        "name": "base",
        "comment": "Flat circular base. Cylinder center at y=base_h/2 so bottom touches y=0.",
        "type": "primitive",
        "primitive": "cylinder",
        "params": { "radius": "$base_r", "height": "$base_h" },
        "transform": {
          "position": [0, "$base_h / 2", 0]
        },
        "material": "metal"
      },
      {
        "name": "pole",
        "comment": "Vertical pole. Bottom sits on top of base (y=base_h), center at y=base_h+pole_h/2.",
        "type": "primitive",
        "primitive": "cylinder",
        "params": { "radius": "$pole_r", "height": "$pole_h" },
        "transform": {
          "position": [0, "$base_h + $pole_h / 2", 0]
        },
        "material": "metal"
      },
      {
        "name": "arm",
        "comment": "Horizontal arm along +X axis. Default cylinder is Y-axis; rotation_euler [0,-90,0] rotates Y->X (yaw=-90 in this engine's Euler convention). Center at [arm_len/2, pole_top, 0] so arm spans x=[0, arm_len].",
        "type": "primitive",
        "primitive": "cylinder",
        "params": { "radius": "$arm_r", "height": "$arm_len" },
        "transform": {
          "position": ["$arm_len / 2", "$base_h + $pole_h", 0],
          "rotation_euler": [0, -90, 0]
        },
        "material": "metal"
      },
      {
        "name": "shade",
        "comment": "Lampshade using bowl component (hollow hemisphere), flipped upside-down so opening faces down.",
        "type": "reference",
        "ref": "bowl_v1",
        "overrides": {
          "radius": "$shade_r",
          "thickness": "$shade_thickness"
        },
        "transform": {
          "position": ["$arm_len", "$base_h + $pole_h", 0],
          "rotation_euler": [0, 0, 180]
        },
        "material": "metal"
      },
      {
        "name": "bulb",
        "comment": "Light bulb sphere inside the hollow shade (bowl interior).",
        "type": "primitive",
        "primitive": "sphere",
        "params": { "radius": "$bulb_r" },
        "transform": {
          "position": ["$arm_len", "$base_h + $pole_h - $shade_r / 2", 0]
        },
        "material": "emissive"
      },
      {
        "name": "bulb_light",
        "comment": "Point light reference at bulb position with custom color.",
        "type": "reference",
        "ref": "point_light_warm_v1",
        "overrides": {
          "color_r": "$light_color_r",
          "color_g": "$light_color_g",
          "color_b": "$light_color_b",
          "intensity": 6.0,
          "range": 180.0
        },
        "transform": {
          "position": ["$arm_len", "$base_h + $pole_h - $shade_r / 2", 0]
        }
      }
    ],
    "output": { "mode": "separate" }
  }
}
