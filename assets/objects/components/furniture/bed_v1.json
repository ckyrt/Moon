{
  "schema_version": 1,
  "name": "bed_v1",
  "description": "Simple bed assembled from reusable legs, panels and mattress blocks. Origin at floor.",
  "version": 2,
  "parameters": {
    "bed_length": 200.0,
    "bed_width": 150.0,
    "leg_height": 35.0,
    "leg_radius": 3.0,
    "leg_inset": 10.0,
    "frame_height": 3.0,
    "frame_thickness": 3.0,
    "mattress_height": 20.0,
    "headboard_height": 80.0,
    "headboard_thickness": 5.0
  },
  "anchors": {
    "bottom_center": [0, 0, 0],
    "top_center": [0, "$leg_height + $frame_height + $mattress_height + $headboard_height", 0],
    "mattress_top": [0, "$leg_height + $frame_height + $mattress_height", 0],
    "center": [0, "($leg_height + $frame_height + $mattress_height) / 2", 0]
  },
  "root": {
    "type": "group",
    "children": [
      {
        "name": "leg_fl",
        "type": "reference",
        "ref": "round_leg_metal_v1",
        "overrides": { "r": "$leg_radius", "h": "$leg_height" },
        "transform": {
          "position": ["$bed_width / 2 - $leg_inset", "$leg_height / 2", "$bed_length / 2 - $leg_inset"]
        }
      },
      {
        "name": "leg_fr",
        "type": "reference",
        "ref": "round_leg_metal_v1",
        "overrides": { "r": "$leg_radius", "h": "$leg_height" },
        "transform": {
          "position": ["-$bed_width / 2 + $leg_inset", "$leg_height / 2", "$bed_length / 2 - $leg_inset"]
        }
      },
      {
        "name": "leg_bl",
        "type": "reference",
        "ref": "round_leg_metal_v1",
        "overrides": { "r": "$leg_radius", "h": "$leg_height" },
        "transform": {
          "position": ["$bed_width / 2 - $leg_inset", "$leg_height / 2", "-$bed_length / 2 + $leg_inset"]
        }
      },
      {
        "name": "leg_br",
        "type": "reference",
        "ref": "round_leg_metal_v1",
        "overrides": { "r": "$leg_radius", "h": "$leg_height" },
        "transform": {
          "position": ["-$bed_width / 2 + $leg_inset", "$leg_height / 2", "-$bed_length / 2 + $leg_inset"]
        }
      },
      {
        "name": "frame",
        "type": "reference",
        "ref": "wood_panel_v1",
        "overrides": { "w": "$bed_width", "h": "$frame_height", "d": "$bed_length" },
        "transform": {
          "position": [0, "$leg_height + $frame_height / 2", 0]
        }
      },
      {
        "name": "mattress",
        "type": "reference",
        "ref": "fabric_block_v1",
        "overrides": {
          "w": "$bed_width - $frame_thickness * 2",
          "h": "$mattress_height",
          "d": "$bed_length - $frame_thickness * 2"
        },
        "transform": {
          "position": [0, "$leg_height + $frame_height + $mattress_height / 2", 0]
        }
      },
      {
        "name": "headboard",
        "type": "reference",
        "ref": "wood_panel_v1",
        "overrides": { "w": "$bed_width", "h": "$headboard_height", "d": "$headboard_thickness" },
        "transform": {
          "position": [0, "$leg_height + $headboard_height / 2", "-$bed_length / 2 + $headboard_thickness / 2"]
        }
      }
    ],
    "output": { "mode": "separate" }
  }
}
