{
  "schema_version": 1,
  "name": "rect_leg_wood_v1",
  "description": "Rectangular wooden furniture leg. Use when profile differs from round wooden legs.",
  "version": 1,
  "parameters": {
    "w": 4.0,
    "d": 4.0,
    "h": 40.0
  },
  "anchors": {
    "center": [0, 0, 0],
    "bottom_center": [0, "-$h / 2", 0],
    "top_center": [0, "$h / 2", 0]
  },
  "root": {
    "type": "reference",
    "ref": "wood_panel_v1",
    "overrides": {
      "w": "$w",
      "h": "$h",
      "d": "$d"
    }
  }
}
