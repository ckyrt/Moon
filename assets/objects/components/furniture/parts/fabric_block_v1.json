{
  "schema_version": 1,
  "name": "fabric_block_v1",
  "description": "Generic upholstered fabric block. Origin at geometric center.",
  "version": 1,
  "parameters": {
    "w": 60.0,
    "h": 20.0,
    "d": 60.0
  },
  "anchors": {
    "center": [0, 0, 0],
    "bottom_center": [0, "-$h / 2", 0],
    "top_center": [0, "$h / 2", 0]
  },
  "root": {
    "type": "primitive",
    "primitive": "cube",
    "params": {
      "size_x": "$w",
      "size_y": "$h",
      "size_z": "$d"
    },
    "material": "fabric"
  }
}
