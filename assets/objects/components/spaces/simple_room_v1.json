{
  "schema_version": 1,
  "name": "simple_room_v1",
  "description": "Simple room shell: floor + 4 walls (no roof) + one window on back wall. Level 4. Origin at exterior ground center (y=0 = bottom of floor). w/d = exterior footprint. h = interior wall height (excludes floor thickness).",
  "version": 1,
  "parameters": {
    "w":     750.0,
    "d":     600.0,
    "h":     350.0,
    "t":      20.0,
    "win_w": 150.0,
    "win_h": 150.0
  },
  "anchors": {
    "bottom_center":   [0, 0, 0],
    "interior_center": [0, "$t + $h / 2", 0],
    "top_center":      [0, "$t + $h", 0]
  },
  "root": {
    "type": "group",
    "children": [
      {
        "name": "floor",
        "comment": "Floor slab. Full exterior footprint. Bottom at y=0, center at y=t/2.",
        "type": "primitive",
        "primitive": "cube",
        "params": { "size_x": "$w", "size_y": "$t", "size_z": "$d" },
        "transform": { "position": [0, "$t / 2", 0] },
        "material": "carpet"
      },
      {
        "name": "wall_front",
        "comment": "Front wall (-Z side) with door opening cut out using CSG subtract.",
        "type": "csg",
        "operation": "subtract",
        "left": {
          "comment": "Solid front wall",
          "type": "primitive",
          "primitive": "cube",
          "params": { "size_x": "$w", "size_y": "$h", "size_z": "$t" },
          "transform": { "position": [0, "$t + $h / 2", "-($d / 2 - $t / 2)"] },
          "material": "brick"
        },
        "right": {
          "comment": "Door opening (door panel 90x200 + frame post_width 8 = total 106x208)",
          "type": "primitive",
          "primitive": "cube",
          "params": { 
            "size_x": 106.0, 
            "size_y": 208.0, 
            "size_z": "$t + 2" 
          },
          "transform": { 
            "position": [0, "$t + 104.0", "-($d / 2 - $t / 2)"] 
          }
        }
      },
      {
        "name": "wall_back",
        "comment": "Back wall (+Z side) with window opening cut out using CSG subtract.",
        "type": "csg",
        "operation": "subtract",
        "left": {
          "comment": "Solid back wall",
          "type": "primitive",
          "primitive": "cube",
          "params": { "size_x": "$w", "size_y": "$h", "size_z": "$t" },
          "transform": { "position": [0, "$t + $h / 2", "$d / 2 - $t / 2"] },
          "material": "brick"
        },
        "right": {
          "comment": "Window opening (slightly deeper to avoid z-fighting)",
          "type": "primitive",
          "primitive": "cube",
          "params": { 
            "size_x": "$win_w", 
            "size_y": "$win_h", 
            "size_z": "$t + 2" 
          },
          "transform": { 
            "position": [0, "$t + $h * 0.6", "$d / 2 - $t / 2"] 
          }
        }
      },
      {
        "name": "wall_left",
        "comment": "Left wall (-X side). Depth = d - 2*t (fits between front and back walls). Center X = -(w/2 - t/2).",
        "type": "primitive",
        "primitive": "cube",
        "params": { "size_x": "$t", "size_y": "$h", "size_z": "$d - 2 * $t" },
        "transform": { "position": ["-($w / 2 - $t / 2)", "$t + $h / 2", 0] },
        "material": "brick"
      },
      {
        "name": "wall_right",
        "comment": "Right wall (+X side). Mirror of left wall.",
        "type": "primitive",
        "primitive": "cube",
        "params": { "size_x": "$t", "size_y": "$h", "size_z": "$d - 2 * $t" },
        "transform": { "position": ["$w / 2 - $t / 2", "$t + $h / 2", 0] },
        "material": "brick"
      },
      {
        "name": "window_back",
        "comment": "Window on back wall. Centered horizontally, sill at 60% of wall height. Embedded in wall thickness (t matched to wall t).",
        "type": "reference",
        "ref": "window_v1",
        "overrides": { "w": "$win_w", "h": "$win_h", "t": "$t" },
        "transform": { "position": [0, "$t + $h * 0.6", "$d / 2 - $t / 2"] }
      },
      {
        "name": "door_front",
        "comment": "Door on front wall. Centered horizontally, floor level at y=$t. Embedded in wall thickness.",
        "type": "reference",
        "ref": "complete_door_v1",
        "overrides": { 
          "door_width": 90.0,
          "door_height": 200.0,
          "frame_depth": "$t"
        },
        "transform": { "position": [0, "$t", "-($d / 2 - $t / 2)"] }
      }
    ],
    "output": { "mode": "separate" }
  }
}
