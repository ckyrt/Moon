{
  "schema_version": 1,
  "name": "staircase_v1",
  "description": "Straight interior stair flight generated procedurally from tread and railing parameters.",
  "version": 2,
  "parameters": {
    "w": 120.0,
    "step_count": 10.0,
    "tread_d": 28.0,
    "step_h": 18.0,
    "step_t": 4.0,
    "stringer_t": 4.0,
    "stringer_h": 12.0,
    "rail_h": 92.0
  },
  "anchors": {
    "bottom_center": [0, 0, 0],
    "top_center": [0, "$step_count * $step_h", "$step_count * $tread_d"],
    "run_end": [0, "$step_count * $step_h", "$step_count * $tread_d"],
    "center": [0, "$step_count * $step_h / 2", "$step_count * $tread_d / 2"]
  },
  "root": {
    "type": "stair",
    "params": {
      "w": "$w",
      "step_count": "$step_count",
      "tread_d": "$tread_d",
      "step_h": "$step_h",
      "step_t": "$step_t",
      "stringer_t": "$stringer_t",
      "stringer_h": "$stringer_h",
      "rail_h": "$rail_h",
      "rail_offset": 3.0,
      "post_spacing": 95.0,
      "post_w": 4.0,
      "handrail_w": 4.0,
      "handrail_t": 4.0
    },
    "materials": {
      "tread": "wood_oak",
      "stringer": "wood_oak",
      "rail": "metal_black"
    },
    "rails": {
      "left": true,
      "right": true
    }
  }
}
