{
  "schema_version": 1,
  "name": "simple_table_v1",
  "description": "Simple table assembled from reusable tabletop and center leg components.",
  "version": 2,
  "anchors": {
    "origin": [0, 0, 0],
    "floor_center": [0, 0, 0],
    "top_surface": [0, "$table_height", 0],
    "center": [0, "$table_height / 2", 0]
  },
  "parameters": {
    "table_length": 120.0,
    "table_width": 80.0,
    "table_height": 75.0,
    "top_thickness": 2.5,
    "leg_radius": 8.0
  },
  "root": {
    "type": "group",
    "children": [
      {
        "name": "top",
        "type": "reference",
        "ref": "table_top_v1",
        "overrides": {
          "w": "$table_length",
          "d": "$table_width",
          "t": "$top_thickness"
        },
        "transform": {
          "position": [0, "$table_height - $top_thickness / 2", 0]
        }
      },
      {
        "name": "center_leg",
        "type": "reference",
        "ref": "round_leg_wood_v1",
        "overrides": {
          "r": "$leg_radius",
          "h": "$table_height - $top_thickness"
        },
        "transform": {
          "position": [0, "($table_height - $top_thickness) / 2", 0]
        }
      }
    ],
    "output": {
      "mode": "separate"
    }
  }
}
