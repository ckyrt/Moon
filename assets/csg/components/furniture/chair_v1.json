{
  "schema_version": 1,
  "name": "chair_v1",
  "description": "Simple chair assembled from reusable legs and upholstered blocks. Origin at floor.",
  "version": 2,
  "parameters": {
    "seat_height": 45.0,
    "seat_thickness": 3.0,
    "seat_width": 45.0,
    "seat_depth": 40.0,
    "backrest_height": 40.0,
    "backrest_thickness": 3.0,
    "leg_radius": 2.5,
    "leg_inset": 5.0
  },
  "anchors": {
    "center": [0, "($seat_height + $seat_thickness + $backrest_height) / 2", 0],
    "bottom_center": [0, 0, 0],
    "top_center": [0, "$seat_height + $seat_thickness + $backrest_height", 0],
    "seat_top": [0, "$seat_height + $seat_thickness", 0]
  },
  "root": {
    "type": "group",
    "children": [
      {
        "name": "leg_fl",
        "type": "reference",
        "ref": "round_leg_wood_v1",
        "overrides": { "r": "$leg_radius", "h": "$seat_height" },
        "transform": {
          "position": ["$seat_width / 2 - $leg_inset", "$seat_height / 2", "$seat_depth / 2 - $leg_inset"]
        }
      },
      {
        "name": "leg_fr",
        "type": "reference",
        "ref": "round_leg_wood_v1",
        "overrides": { "r": "$leg_radius", "h": "$seat_height" },
        "transform": {
          "position": ["$seat_width / 2 - $leg_inset", "$seat_height / 2", "-$seat_depth / 2 + $leg_inset"]
        }
      },
      {
        "name": "leg_bl",
        "type": "reference",
        "ref": "round_leg_wood_v1",
        "overrides": { "r": "$leg_radius", "h": "$seat_height" },
        "transform": {
          "position": ["-$seat_width / 2 + $leg_inset", "$seat_height / 2", "$seat_depth / 2 - $leg_inset"]
        }
      },
      {
        "name": "leg_br",
        "type": "reference",
        "ref": "round_leg_wood_v1",
        "overrides": { "r": "$leg_radius", "h": "$seat_height" },
        "transform": {
          "position": ["-$seat_width / 2 + $leg_inset", "$seat_height / 2", "-$seat_depth / 2 + $leg_inset"]
        }
      },
      {
        "name": "seat",
        "type": "reference",
        "ref": "fabric_block_v1",
        "overrides": { "w": "$seat_width", "h": "$seat_thickness", "d": "$seat_depth" },
        "transform": {
          "position": [0, "$seat_height + $seat_thickness / 2", 0]
        }
      },
      {
        "name": "backrest",
        "type": "reference",
        "ref": "fabric_block_v1",
        "overrides": { "w": "$seat_width", "h": "$backrest_height", "d": "$backrest_thickness" },
        "transform": {
          "position": [0, "$seat_height + $seat_thickness + $backrest_height / 2", "-$seat_depth / 2 + $backrest_thickness / 2"]
        }
      }
    ],
    "output": { "mode": "separate" }
  }
}
