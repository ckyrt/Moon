{
  "schema_version": 1,
  "name": "table_v1",
  "description": "Standard table using anchor-attach system. Origin at floor (y=0 = bottom of legs). Leg Y is automatically computed via attach.",
  "version": 1,
  "parameters": {
    "w":     120.0,
    "d":      80.0,
    "h":      73.0,
    "t":       3.0,
    "r":       3.0,
    "inset":  10.0
  },
  "anchors": {
    "center":        [0, "($h + $t) / 2", 0],
    "bottom_center": [0, 0,                0],
    "top_center":    [0, "$h + $t",        0]
  },
  "root": {
    "type": "group",
    "children": [
      {
        "name": "top",
        "type": "reference",
        "ref": "table_top_v1",
        "overrides": { "w": "$w", "d": "$d", "t": "$t" },
        "transform": { "position": [0, "$h + $t / 2", 0] }
      },
      {
        "name": "leg_fl",
        "type": "reference",
        "ref": "table_leg_v1",
        "overrides": { "h": "$h", "r": "$r" },
        "attach": {
          "self_anchor":   "top_center",
          "target_path":   "../top",
          "target_anchor": "bottom_center"
        },
        "transform": { "position": ["$w / 2 - $inset", 0, "$d / 2 - $inset"] }
      },
      {
        "name": "leg_fr",
        "type": "reference",
        "ref": "table_leg_v1",
        "overrides": { "h": "$h", "r": "$r" },
        "attach": {
          "self_anchor":   "top_center",
          "target_path":   "../top",
          "target_anchor": "bottom_center"
        },
        "transform": { "position": ["$w / 2 - $inset", 0, "-$d / 2 + $inset"] }
      },
      {
        "name": "leg_bl",
        "type": "reference",
        "ref": "table_leg_v1",
        "overrides": { "h": "$h", "r": "$r" },
        "attach": {
          "self_anchor":   "top_center",
          "target_path":   "../top",
          "target_anchor": "bottom_center"
        },
        "transform": { "position": ["-$w / 2 + $inset", 0, "$d / 2 - $inset"] }
      },
      {
        "name": "leg_br",
        "type": "reference",
        "ref": "table_leg_v1",
        "overrides": { "h": "$h", "r": "$r" },
        "attach": {
          "self_anchor":   "top_center",
          "target_path":   "../top",
          "target_anchor": "bottom_center"
        },
        "transform": { "position": ["-$w / 2 + $inset", 0, "-$d / 2 + $inset"] }
      }
    ],
    "output": { "mode": "separate" }
  }
}
