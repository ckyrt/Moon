{
  "schema_version": 1,
  "name": "table_top_v1",
  "description": "Table top slab. Origin at geometric center (y=0 is mid-thickness).",
  "version": 1,
  "parameters": {
    "w": 120.0,
    "d": 80.0,
    "t": 3.0
  },
  "anchors": {
    "center":        [0, 0, 0],
    "bottom_center": [0, "-$t / 2", 0],
    "top_center":    [0, "$t / 2",  0]
  },
  "root": {
    "type": "primitive",
    "primitive": "cube",
    "params": {
      "size_x": "$w",
      "size_y": "$t",
      "size_z": "$d"
    },
    "material": "wood"
  }
}
