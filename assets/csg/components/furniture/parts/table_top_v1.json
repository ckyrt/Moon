{
  "schema_version": 1,
  "name": "table_top_v1",
  "description": "Legacy tabletop wrapper built on the generic wood panel part.",
  "version": 2,
  "parameters": {
    "w": 120.0,
    "d": 80.0,
    "t": 3.0
  },
  "anchors": {
    "center": [0, 0, 0],
    "bottom_center": [0, "-$t / 2", 0],
    "top_center": [0, "$t / 2", 0]
  },
  "root": {
    "type": "reference",
    "ref": "wood_panel_v1",
    "overrides": {
      "w": "$w",
      "h": "$t",
      "d": "$d"
    }
  }
}
