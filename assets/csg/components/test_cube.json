{
  "schema_version": 1,
  "name": "test_cube",
  "description": "Test cube - should be centered at origin",
  "version": 1,
  "parameters": {
    "w": 100.0,
    "h": 100.0,
    "d": 100.0
  },
  "anchors": {
    "origin":        [0, 0, 0],
    "bottom_center": [0, "-$h / 2", 0],
    "top_center":    [0, "$h / 2", 0]
  },
  "root": {
    "type": "primitive",
    "primitive": "cube",
    "params": {
      "size_x": "$w",
      "size_y": "$h",
      "size_z": "$d"
    },
    "material": "metal"
  }
}
