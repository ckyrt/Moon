{
  "schema_version": 1,
  "name": "door_v1",
  "description": "Simple door with handle - using group (no CSG needed)",
  "version": 1,
  "parameters": {
    "door_width": 90.0,
    "door_height": 200.0,
    "door_thickness": 4.0,
    "handle_width": 4.0,
    "handle_height": 20.0,
    "handle_protrusion": 6.0
  },
  "anchors": {
    "origin":       [0, 0, 0],
    "top_center":   [0, "$door_height", 0],
    "hinge_bottom": ["0 - $door_width / 2", 0, 0],
    "hinge_top":    ["0 - $door_width / 2", "$door_height", 0],
    "handle_pos":   ["$door_width / 2 - 15", 100, "$door_thickness / 2"]
  },
  "root": {
    "type": "group",
    "children": [
      {
        "type": "primitive",
        "primitive": "cube",
        "params": {
          "size_x": "$door_width",
          "size_y": "$door_height",
          "size_z": "$door_thickness"
        },
        "transform": {
          "position": [0, "$door_height / 2", 0]
        },
        "material": "wood"
      },
      {
        "type": "primitive",
        "primitive": "cube",
        "params": {
          "size_x": "$handle_width",
          "size_y": "$handle_height",
          "size_z": "$door_thickness + $handle_protrusion * 2"
        },
        "transform": {
          "position": ["$door_width / 2 - 15", 100.0, 0]
        },
        "material": "metal"
      }
    ],
    "output": {
      "mode": "separate"
    }
  }
}
