{
  "schema_version": 1,
  "id": "wheel_v1",
  "category": "component",
  "tags": ["wheel", "component", "vehicle"],
  "parameters": {
    "radius": {
      "type": "float",
      "default": 0.5,
      "min": 0.1,
      "max": 2.0
    },
    "thickness": {
      "type": "float",
      "default": 0.2,
      "min": 0.05,
      "max": 1.0
    }
  },
  "root": {
    "type": "csg",
    "operation": "subtract",
    "left": {
      "type": "primitive",
      "primitive": "cylinder",
      "params": {
        "radius": "$radius",
        "height": "$thickness"
      },
      "transform": {
        "position": [0, 0, 0],
        "rotation_euler": [90, 0, 0],
        "scale": [1, 1, 1]
      },
      "material": "rubber"
    },
    "right": {
      "type": "primitive",
      "primitive": "cylinder",
      "params": {
        "radius": 0.3,
        "height": "$thickness"
      },
      "transform": {
        "position": [0, 0, 0],
        "rotation_euler": [90, 0, 0],
        "scale": [1, 1, 1]
      },
      "material": "default"
    }
  }
}
