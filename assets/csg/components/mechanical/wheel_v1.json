{
  "schema_version": 1,
  "id": "wheel_v1",
  "category": "component",
  "tags": ["wheel", "component", "vehicle"],
  "parameters": {
    "radius": {
      "type": "float",
      "default": 50.0,
      "min": 10.0,
      "max": 200.0
    },
    "thickness": {
      "type": "float",
      "default": 20.0,
      "min": 5.0,
      "max": 100.0
    }
  },
  "anchors": {
    "origin":      [0, 0, 0],
    "axle_center": [0, 0, 0],
    "face_front":  [0, "$thickness / 2", 0],
    "face_back":   [0, "0 - $thickness / 2", 0]
  },
  "root": {
    "type": "csg",
    "operation": "subtract",
    "left": {
      "type": "primitive",
      "primitive": "cylinder",
      "params": {
        "radius": "$radius",
        "height": "$thickness"
      },
      "material": "rubber"
    },
    "right": {
      "type": "primitive",
      "primitive": "cylinder",
      "params": {
        "radius": 30.0,
        "height": "$thickness"
      },
      "material": "default"
    }
  }
}
