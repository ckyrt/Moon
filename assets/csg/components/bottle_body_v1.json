{
  "schema_version": 1,
  "name": "bottle_body_v1",
  "description": "Bottle body (simple hollow cylinder)",
  "version": 1,
  "parameters": {
    "radius": 3.5,
    "height": 20.0,
    "thickness": 0.2
  },
  "root": {
    "type": "csg",
    "operation": "subtract",
    "left": {
      "type": "primitive",
      "primitive": "cylinder",
      "params": {
        "radius": "$radius",
        "height": "$height"
      }
    },
    "right": {
      "type": "primitive",
      "primitive": "cylinder",
      "params": {
        "radius": "$radius - $thickness",
        "height": "$height - $thickness"
      },
      "transform": {
        "position": [0, "($height + $thickness) / 2 - $height / 2", 0]
      }
    }
  }
}
